{
  "niri/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "cursor": true,
    "format": "{icon}"
  },
  "niri/window": { 
    "format": "{}",
    "max-length": 20
  },
  "custom/separator": {
    "format": "|", 
    "tooltip": false
  },

  "custom/omarchy": {
    "format": "ï†©",
    "on-click-right": "xdg-terminal-exec",
  },
  "custom/updates": {
    /*"format": "َ°ڈ– {}",*/
    "format": "ï€، {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/ml4w/scripts/ml4w-check-system-updates",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "~/.config/ml4w/settings/installupdates.sh",
    "on-click-right": "~/.config/ml4w/settings/software.sh"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "performance": "î½¶",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬"
    }
  },
  "cpu": {
    "interval": 10,
    "format": "cpu {usage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
  "backlight": {
        "device": "intel_backlight",
        "rotate": 0,
        "format": "{icon}",
        "tooltip-format": "ًںŒ• {percent}%",
            "format-icons": [
      "َ°ƒœ",
      "َ°ƒ‌",
      "َ°ƒ‍",
      "َ°ƒں",
      "َ°ƒ "
    ],
        "scroll-step": 1,
        "min-length": 2
    },
  "memory": {
    "interval": 2,
    "format": "mem {}%",
    "on-click": "~/.config/ml4w/settings/system-monitor.sh",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:L%a, %B %d %Y}",
    "tooltip-format": "<span>{calendar}</span>",
    "justify": "right",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>",
      },
    },
  },
  "network": {
    "format-icons": [
      "َ°¤¯",
      "َ°¤ں",
      "َ°¤¢",
      "َ°¤¥",
      "َ°¤¨"
    ],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "َ°Œ—",
    "format-disconnected": "َ°¤®",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-ethernet": "â‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "~/.config/ml4w/settings/networkmanager.sh",
  },
  "battery": {
    "format": "bat {capacity}%",
    "format-discharging": "bat {capacity}%",
    "format-charging": "bat {capacity}%",
    "format-plugged": "bat_p {capacity}%",
    "format-icons": {
      "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
      "default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },
    "format-full": "bat_f {capacity}%",
    "tooltip-format-discharging": "{power:>1.0f}Wâ†“ {capacity}%\n {timeTo}",
    "tooltip-format-charging": "{power:>1.0f}Wâ†‘ {capacity}%\n {timeTo}",
    "interval": 5,
    "states": {
      "warning": 30,
      "critical": 15
    }
  },
  "bluetooth": {
    "format": "ïٹ”",
    "format-disabled": "َ°‚²",
    "format-connected": "َ°‚±",
    "format-off": "",
    "interval": 30,
    "on-click": "sleep 0.1 && ~/.config/ml4w/settings/bluetooth.sh",
    "tooltip-format-connected": "Connected devices: {num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t| Battery life: {device_battery_percentage}%",
    "format-no-controller": ""
  },
  "pulseaudio": {
    "format": "vol {volume}%",
    "on-click": "pavucontrol",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "vol 0%",
    "format-icons": {
      "headphone": "ï€¥",
      "headset": "ï€¥",
      "default": ["ï€¦", "ï€§", "ï€¨"],
      "muted": "î»¨"

    }
  },
   "mpris": {
    "format": "î°› {artist} - {title}",
    "format-paused": "<span color='grey'>{status_icon}</span>",
    "max-length": 30,
    "player-icons": {
      "default": "âڈ¸",
      "mpv": "ًںژµ"
    },
    "status-icons": {
      "paused": "َ°‌›"
    },
    "ignored-players": ["chromium", "brave"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "î°•",
      "deactivated": "َ°¾«"
    }
  },
  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": [
      "custom/expand-icon",
      // "custom/separator",
      "power-profiles-daemon",
      "network",
      // "backlight",
      "bluetooth",
      "custom/separator"
      ]
  },
  "custom/expand-icon": {
    "format": "ïپ“",
    "tooltip": false
  },
  "tray": {
    "icon-size": 12,
    "spacing": 4
  },
  // VPN
  "custom/vpn": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/themes/custom1/vpn-waybar.sh",
    "return-type": "json",
    "interval": 60, 
    "signal": 8,    
    "on-click": "$HOME/.config/waybar/themes/custom1/vpn-waybar.sh menu",
    "tooltip": true
  }
}
